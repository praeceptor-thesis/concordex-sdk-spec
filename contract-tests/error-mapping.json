{
  "$schema_version": "0.5.0",
  "$description": "HTTP status → canonical exception. Runner stubs the SDK's HTTP transport to return the fixture's status + body, calls method, and asserts the raised exception's canonical type matches `expected_exception`. Each SDK runner maps the canonical name to its language type (see sdk-spec.md §8.5).",
  "fixtures": [
    {
      "name": "400_validation",
      "status": 400,
      "body": { "detail": "kind must be one of ..." },
      "method": "subject_says",
      "args": { "agent_subject_id": "user:ws_test:bot", "subject_id": "user:ws_test:cust", "text": "hi" },
      "expected_exception": "ValidationError",
      "expected_status_code": 400
    },
    {
      "name": "401_auth",
      "status": 401,
      "body": { "detail": "invalid api key" },
      "method": "subject_says",
      "args": { "agent_subject_id": "user:ws_test:bot", "subject_id": "user:ws_test:cust", "text": "hi" },
      "expected_exception": "AuthError",
      "expected_status_code": 401
    },
    {
      "name": "403_permission",
      "status": 403,
      "body": { "detail": "scope not granted" },
      "method": "subject_says",
      "args": { "agent_subject_id": "user:ws_test:bot", "subject_id": "user:ws_test:cust", "text": "hi" },
      "expected_exception": "PermissionError",
      "expected_status_code": 403
    },
    {
      "name": "500_server",
      "status": 500,
      "body": { "detail": "internal error" },
      "method": "subject_says",
      "args": { "agent_subject_id": "user:ws_test:bot", "subject_id": "user:ws_test:cust", "text": "hi" },
      "expected_exception": "ServerError",
      "expected_status_code": 500
    },
    {
      "name": "503_server",
      "status": 503,
      "body": { "detail": "upstream unavailable" },
      "method": "subject_says",
      "args": { "agent_subject_id": "user:ws_test:bot", "subject_id": "user:ws_test:cust", "text": "hi" },
      "expected_exception": "ServerError",
      "expected_status_code": 503
    },
    {
      "name": "418_unexpected",
      "status": 418,
      "body": "i am a teapot",
      "method": "subject_says",
      "args": { "agent_subject_id": "user:ws_test:bot", "subject_id": "user:ws_test:cust", "text": "hi" },
      "expected_exception": "ConcordexError",
      "expected_status_code": 418
    },
    {
      "name": "guard_open_raises_cb_open",
      "status": 200,
      "body": {
        "state": "open",
        "allow": false,
        "warning": false,
        "reason": "policy:risk.refund_velocity fired",
        "fired_policies": [
          { "cb_policy_id": "pol_123", "name": "refund_velocity", "action": "open" }
        ],
        "anchor": { "ledger_index": 1234, "hash": "0xdeadbeef" },
        "checked_at": "2026-05-30T12:00:00Z",
        "latency_ms": 7.2,
        "route_latency_ms": 11.4
      },
      "method": "guard_with_raise_on_open",
      "args": { "subject_id": "user:ws_test:bot", "raise_on_open": true },
      "expected_exception": "CBOpenError",
      "expected_fields": {
        "reason": "policy:risk.refund_velocity fired",
        "scope_ref": "user:ws_test:bot"
      }
    },
    {
      "name": "guard_open_no_raise_returns_result",
      "status": 200,
      "body": {
        "state": "open",
        "allow": false,
        "warning": false,
        "reason": "policy:risk.refund_velocity fired",
        "fired_policies": [],
        "anchor": null,
        "checked_at": "2026-05-30T12:00:00Z",
        "latency_ms": 5.0,
        "route_latency_ms": 8.0
      },
      "method": "guard_with_raise_on_open",
      "args": { "subject_id": "user:ws_test:bot", "raise_on_open": false },
      "expected_exception": null,
      "expected_result_fields": {
        "allow": false,
        "state": "open"
      }
    }
  ]
}
